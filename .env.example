API_KEY=sk-or-v1-your-openrouter-key
WHISPER_MODEL_FILE=ggml-base.bin
WHISPER_LANGUAGE=es
WHISPER_THREADS=4

# LLM fallback and reconnector settings
LLM_FALLBACK_POLICY=cascade
LLM_RECONNECT_INTERVAL_MS=30000
LLM_RECONNECT_MAX_ATTEMPTS=10
LMSTUDIO_PREFERRED_MODEL=gemma-3-12b-instruct
LLM_TIMEOUT_LOCAL_MS=120000
LLM_TIMEOUT_CLOUD_MS=45000

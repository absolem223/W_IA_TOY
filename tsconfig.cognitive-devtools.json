{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "out-cognitive-devtools",
    "types": ["node"]
  },
  "include": ["src/cognitive/**/*", "src/shared/**/*", "src/cognitive-devtools/**/*", "tests/cognitive-devtools/**/*", "src/renderer/env.d.ts"]
}
